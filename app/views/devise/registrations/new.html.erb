<%# Centered card holding the sign up form %>
<div class="auth">
  <div class="auth-card">

    <%# Card title %>
    <h1 class="auth-title">Enregistrez-vous</h1>
    <p class="auth-subtitle">Créez votre compte pour commencer.</p>

    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name),
                        html: { data: { controller: "role-selector" } }) do |f| %>
      <%= f.error_notification %>

      <div class="form-inputs">
        <%# Choose your profile: Dreamer (orange) or Maker (blue).
            The selected button fills the hidden role field below. %>
        <div class="role-toggle">
          <button type="button" class="role-btn role-btn-dreamer"
                  data-role="dreamer"
                  data-role-selector-target="dreamerButton"
                  data-action="role-selector#choose">Dreamer</button>
          <button type="button" class="role-btn role-btn-maker"
                  data-role="maker"
                  data-role-selector-target="makerButton"
                  data-action="role-selector#choose">Maker</button>
        </div>

        <%# Hidden role, pre-filled from the link the visitor clicked (or empty) %>
        <%= f.hidden_field :role, value: @role,
                           data: { "role-selector-target": "input" } %>

        <%# Maker-only fields, shown by the controller only when "maker" is chosen %>
        <div class="role-maker-fields" data-role-selector-target="makerFields" <%= "hidden" unless @role == "maker" %>>
          <%= f.input :skills, as: :select,
            collection: User::SKILLS,
            label: "Mes compétences",
            input_html: { data: { "role-selector-target": "skills" } } %>
        </div>

        <%= f.input :username, required: true, label: "Nom d'utilisateur" %>
        <%= f.input :phone_number, required: true, label: "Numéro de téléphone" %>
        <%= f.input :adresse, required: true, label: "Adresse" %>
        <%= f.input :email, label: "Email",
                    required: true,
                    autofocus: true,
                    input_html: { autocomplete: "email" } %>
        <%= f.input :password, label: "Mot de passe",
                    required: true,
                    hint: ("#{@minimum_password_length} characters minimum" if @minimum_password_length),
                    input_html: { autocomplete: "new-password" } %>
        <%= f.input :password_confirmation, label: "Confirmer le mot de passe",
                    required: true,
                    input_html: { autocomplete: "new-password" } %>
      </div>

      <div class="form-actions">
        <%= f.button :submit, "S'enregistrer" %>
      </div>
    <% end %>

    <%# Links to log in, forgot password, etc. %>
    <div class="auth-links">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>
