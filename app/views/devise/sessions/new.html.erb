<%# Centered card holding the log in form %>
<div class="auth">
  <div class="auth-card">

    <%# Card title and subtitle %>
    <h1 class="auth-title">Connexion</h1>
    <p class="auth-subtitle">Heureux de vous revoir </p>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="form-inputs">
        <%= f.input :email,
                    required: false,
                    autofocus: true,
                    label: "Email",
                    input_html: { autocomplete: "email" } %>
        <%= f.input :password,
                    required: false,
                    label: "Mot de passe",
                    input_html: { autocomplete: "current-password" } %>
        <%= f.input :remember_me, as: :boolean, label: "Se souvenir de moi" if devise_mapping.rememberable? %>
      </div>

      <div class="form-actions">
        <%= f.button :submit, "Se connecter" %>
      </div>
    <% end %>

    <%# Links to sign up, forgot password, etc. %>
    <div class="auth-links">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>
