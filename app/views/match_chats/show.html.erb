<div class="container my-5">

  <%# The conversation lives in a Turbo Frame so it can be loaded into the
      discussions list page (right column) just by clicking a discussion. %>
  <%= turbo_frame_tag "conversation" do %>

    <%# Subscribe this frame to the chat stream, so new messages appear live %>
    <%= turbo_stream_from @match_chat %>

    <%# Title + interlocutor on the left, action buttons on the far right %>
    <div class="chat-header mb-4">

      <%# Project name and the person you are talking to %>
      <div class="chat-header-info">
        <h1>Chat — <%= @match_chat.maker_project.project.title %></h1>

        <%# The other participant, seen from the logged-in user.
            A maker name links to his public page (full page via turbo_frame
            "_top", so it does not load inside the chat frame). %>
        <% other = @match_chat.other_user(current_user) %>
        <p class="chat-with">
          avec
          <% if other.maker? %>
            <%= link_to other.username, maker_path(other), data: { turbo_frame: "_top" }, class: "maker-link" %>
          <% else %>
            <%= other.username %>
          <% end %>
        </p>
      </div>

      <%# Action buttons on the right %>
      <div class="chat-header-actions">
        <%# Button to open the project this chat is about. %>
        <%= link_to "Voir le projet", project_path(@match_chat.maker_project.project),
                    data: { turbo_frame: "_top" },
                    class: "btn btn-outline-secondary btn-sm" %>

        <%# Maker action: mark the project realised %>
        <%= render "maker_projects/progress_buttons", maker_project: @match_chat.maker_project %>

        <%# Dreamer action: confirm reception (photo + rating) %>
        <%= render "maker_projects/receive_button", maker_project: @match_chat.maker_project %>
      </div>
    </div>

    <%# The box that holds all the messages (fixed height, scrolls inside) %>

    <%# Déclaraer mon data-controller pour le scroll dans cette div %>
    <div class="chat-box mb-4" data-controller="scroll">

      <%# Container that receives the live messages (id used by the broadcast) %>
      <div id="<%= dom_id(@match_chat) %>_messages">
        <%# Show every message of this chat, oldest first %>
        <%= render partial: "match_messages/match_message", collection: @match_messages, as: :message %>
      </div>

      <%# Small text shown when there is no message yet %>
      <% if @match_messages.empty? %>
        <p class="text-center text-muted my-5">Aucun message pour l'instant. Lancez la conversation ci-dessous !</p>
      <% end %>

    </div>

    <%# Form to write and send a new message %>
    <%= render "form", match_chat: @match_chat, match_message: @match_message %>

  <% end %>

</div>
