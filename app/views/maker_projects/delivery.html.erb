<div class="container my-5">

  <%# Back to the project page %>
  <%= link_to "← Retour au projet", project_path(@project), class: "btn btn-outline-secondary btn-sm mb-3" %>

  <%# "delivered" already = the dreamer is editing the photo/rating afterwards %>
  <% editing = @maker_project.status == "delivered" %>

  <div class="delivery-card">
    <h1><%= editing ? "Modifier la note et la photo" : "Réception du projet" %></h1>
    <p class="delivery-intro">
      <% if editing %>
        Mettez à jour la photo du résultat et la note de
        <strong><%= @maker_project.maker.username %></strong> pour
        « <%= @project.title %> ». Tout cela apparaît sur sa page publique.
      <% else %>
        Confirmez la réception de « <%= @project.title %> » réalisé par
        <strong><%= @maker_project.maker.username %></strong>.
        Ajoutez une photo du résultat et notez le maker : tout cela apparaîtra sur sa page publique.
      <% end %>
    </p>

    <%# The form sends the photo and the rating, then marks the project delivered %>
    <%= form_with url: mark_delivered_project_path(@project), method: :patch do |f| %>

      <%# Photo of the finished project. Custom button so it reads
          "Choisir un fichier" instead of the browser's "Choose File". %>
      <div class="delivery-field" data-controller="file-input">
        <%= f.label :delivery_photo, "Photo du projet fini" %>

        <%# Show the current photo when editing %>
        <% if @maker_project.delivery_photo.attached? %>
          <%= image_tag @maker_project.delivery_photo, class: "delivery-current-photo" %>
        <% end %>

        <div class="file-input-row">
          <%# The label opens the file dialog; the real input is hidden %>
          <label class="file-input-button">
            Choisir un fichier
            <%= f.file_field :delivery_photo, accept: "image/*", class: "file-input-hidden",
                  data: { action: "change->file-input#show" } %>
          </label>
          <%# Shows the chosen file name (updated by the Stimulus controller) %>
          <span class="file-input-name" data-file-input-target="name">
            <%= @maker_project.delivery_photo.attached? ? "Photo actuelle conservée" : "Aucun fichier choisi" %>
          </span>
        </div>
      </div>

      <%# Rating from 1 to 5 stars (pre-filled with the current note when editing) %>
      <div class="delivery-field">
        <span class="delivery-label">Votre note</span>
        <%# Stars are generated from 5 down to 1 so that, with the CSS
            "row-reverse", they read 1→5 left to right and the highlight fills
            correctly. Generating them 1→5 would invert the values (bug). %>
        <div class="delivery-stars">
          <% 5.downto(1) do |n| %>
            <%= f.radio_button :rating, n, required: true, id: "rating_#{n}",
                  class: "delivery-star-input", checked: (@maker_project.rating == n) %>
            <%= f.label "rating_#{n}", "★", class: "delivery-star" %>
          <% end %>
        </div>
      </div>

      <%= f.submit(editing ? "Enregistrer les modifications" : "Confirmer la réception", class: "btn btn-success") %>
    <% end %>
  </div>

</div>
