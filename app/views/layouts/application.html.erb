<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Dreamer X Maker, là où l'idée rencontre le savoir faire" %></title>

    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Dreamer X Maker">
    <meta name="mobile-web-app-capable" content="yes">

    <meta property="og:title" content="Dreamer x Maker">
    <meta property="og:description" content="Là où l'idée rencontre le savoir faire. Décrivez l'objet dont vous rêvez. On le met en image, puis on vous met en relation avec l'artisan capable de le fabriquer.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://www.dreamer-x-maker.me/">
    <meta property="og:image" content="https://www.dreamer-x-maker.me/iconApp.png">


    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%# Logged-in user id, used by the chat to place messages left or right %>
    <% if user_signed_in? %>
      <meta name="current-user-id" content="<%= current_user.id %>">
    <% end %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <!-- <link rel="icon" href="/icon.png" type="image/png"> -->
    <!-- <link rel="icon" href="/icon.svg" type="image/svg+xml"> -->
    <%= favicon_link_tag %>
    <!-- <link rel="apple-touch-icon" href="/icon.png"> -->

    <%# Fonts used for the brand name "Dreamer x Maker" %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cedarville+Cursive&family=Just+Another+Hand&display=swap" rel="stylesheet">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>


  </head>

  <%# Turbo prefetches links on hover by default. We turn it off because some
      links (opening a chat) run side effects (mark messages as read) that must
      happen on a real click, not on hover. %>
  <%# The role class drives the accent color of the whole UI:
      orange for a dreamer, blue for a maker (see _buttons.scss). %>
  <body id="body" data-turbo-prefetch="false" class="<%= "is-#{current_user.role}" if user_signed_in? %>">
    <%= render "shared/navbar" %>
    <%= render "shared/flashes" %>

    <%# Main content. It grows to fill the space so the footer stays at the
        very bottom of the page, even when the page is short. %>
    <main class="page-main">
      <%= yield %>
    </main>

    <%= render "shared/footer" %>
  </body>
</html>
