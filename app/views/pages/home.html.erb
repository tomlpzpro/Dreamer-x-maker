<%# ======================================================================= %>
<%# HERO: full-width two-tone background (orange = Dreamer, turquoise =     %>
<%# Maker) with a cream card floating in the middle. This is outside the    %>
<%# container so the colored background spans the whole page width.         %>
<%# ======================================================================= %>
<div class="home-hero">
  <div class="container">
    <div class="home-hero-card">

      <%# Small label above the brand name %>
      <p class="home-surtitle">Sur-mesure</p>

      <%# Brand name: "Dreamer" orange, "x" ink, "Maker" turquoise %>
      <p class="home-brand">
        <span class="word-dreamer">Dreamer</span>
        <span class="word-x">x</span>
        <span class="word-maker">Maker</span>
      </p>

      <%# Tagline in the serif font %>
      <h1>Là où l'idée rencontre le savoir faire.</h1>

      <%# Short description of the platform %>
      <p class="home-lead">Décrivez l'objet dont vous rêvez. On le met en image,
         puis on vous met en relation avec l'artisan capable de le fabriquer.</p>

      <%# Buttons depend on whether the visitor is logged in.
          Logged in: one button to the dashboard.
          Not logged in: two sign up buttons (Dreamer orange, Maker turquoise outline). %>
      <% if user_signed_in? %>
        <%= link_to "Aller à mon dashboard", dashboard_path, class: "btn btn-primary mx-2" %>
      <% else %>
        <%= link_to "Créer mon objet", new_user_registration_path(role: "dreamer"), class: "btn btn-primary mx-2" %>
        <%= link_to "Devenir maker", new_user_registration_path(role: "maker"), class: "btn btn-outline-secondary mx-2" %>
      <% end %>

    </div>
  </div>
</div>

<div class="container">

  <%# ===================================================================== %>
  <%# HOW IT WORKS: 3 simple steps. Captured here so we can show it at the    %>
  <%# top for visitors, or move it to the very bottom for logged-in users.    %>
  <%# ===================================================================== %>
  <% how_it_works = capture do %>
    <div class="home-section">
      <div class="home-section-head">
        <h2>Comment ça marche</h2>
        <p>Du rêve à l'objet, en trois étapes simples.</p>
      </div>

      <div class="home-steps">

        <%# Step 1 %>
        <div class="home-step">
          <div class="step-icon"><i class="fas fa-lightbulb"></i></div>
          <h3>Décrivez votre idée</h3>
          <p>Expliquez en quelques mots l'objet sur mesure dont vous rêvez.</p>
        </div>

        <%# Step 2 %>
        <div class="home-step">
          <div class="step-icon"><i class="fas fa-wand-magic-sparkles"></i></div>
          <h3>Visualisez-le</h3>
          <p>Notre IA met votre idée en image pour la rendre concrète.</p>
        </div>

        <%# Step 3 %>
        <div class="home-step">
          <div class="step-icon"><i class="fas fa-handshake"></i></div>
          <h3>Rencontrez la main</h3>
          <p>On vous met en relation avec l'artisan capable de le fabriquer.</p>
        </div>
      </div>
    </div>
  <% end %>

  <%# Visitors see "how it works" right away; logged-in users see it at the bottom %>
  <%= how_it_works unless user_signed_in? %>

  <%# ===================================================================== %>
  <%# TWO UNIVERSES: the Dreamer and the Maker meeting at the "x". Captured   %>
  <%# here so we can show it at the top for visitors, or move it to the very  %>
  <%# bottom for logged-in users (same as "how it works").                    %>
  <%# ===================================================================== %>
  <% two_universes = capture do %>
    <div class="home-section">
      <div class="home-universes">

        <%# Dreamer side (orange, warm) %>
        <div class="home-universe is-dreamer">
          <p class="universe-label">L'idée</p>
          <p class="universe-name">Dreamer</p>
          <p>Celui ou celle qui imagine un objet sur mesure et cherche la bonne personne pour le créer.</p>
        </div>

        <%# The "x" where the two universes meet %>
        <div class="universe-cross">x</div>

        <%# Maker side (turquoise, cold) %>
        <div class="home-universe is-maker">
          <p class="universe-label">La main</p>
          <p class="universe-name">Maker</p>
          <p>L'artisan, l'atelier ou le studio qui possède le savoir-faire pour donner vie au projet.</p>
        </div>
      </div>
    </div>
  <% end %>

  <%# Visitors see the two universes here; logged-in users see them at the bottom %>
  <%= two_universes unless user_signed_in? %>

  <%# ===================================================================== %>
  <%# FEATURED PROJECTS: real projects from the database                    %>
  <%# ===================================================================== %>
  <div class="home-section">
    <div class="home-section-head">
      <h2>Les projets déjà publiés</h2>
      <p>Des idées sur mesure qui cherchent leur artisan.</p>
    </div>

    <div class="row">
      <%# Show the first 3 projects, one card each %>
      <% @projects.first(3).each do |project| %>
        <div class="col-md-4 mb-4">
          <%# Wrapper kept relative so the maker action buttons can sit over the card %>
          <div class="project-card-wrapper">
            <%= link_to project_path(project), class: "home-project-link" do %>
              <div class="card-trip">
                <%# Status badge shown over the image %>
                <span class="card-status status-badge <%= project.matched? ? 'status-accepted' : 'status-pending' %>"><%= project.status_label %></span>
                <%# Project image, or a placeholder if there is none %>
                <% if project.image.attached? %>
                  <%= image_tag project.image %>
                <% else %>
                  <img src="https://raw.githubusercontent.com/lewagon/fullstack-images/master/uikit/greece.jpg" />
                <% end %>
                <div class="card-trip-infos">
                  <div>
                    <h2><%= project.title %></h2>
                  </div>
                </div>
              </div>
            <% end %>

            <%# A logged-in maker can match or dismiss a project he can still act on %>
            <% if user_signed_in? && current_user.maker? && project.open_for?(current_user) %>
              <%# Action buttons placed over the card, outside the link to avoid nested links %>
              <div class="project-card-actions">
                <%# Match this project: creates the match and opens the discussion %>
                <%= link_to "🤝 Matcher", match_project_path(project), data: { turbo_method: :post }, class: "card-action-btn card-action-match" %>
                <%# Dismiss this project: it will no longer appear in my available projects %>
                <%= link_to "✕ Pas pour moi", dismiss_project_path(project), data: { turbo_method: :post }, class: "card-action-btn card-action-dismiss" %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <%# Button to see the full page with every published project %>
    <div class="home-section-foot">
      <%= link_to "Voir tous les projets publiés", published_projects_path, class: "btn btn-primary" %>
    </div>
  </div>

  <%# ===================================================================== %>
  <%# COMPLETED PROJECTS: only shown to visitors who are NOT logged in      %>
  <%# ===================================================================== %>
  <% unless user_signed_in? %>
    <div class="home-section">
      <div class="home-section-head">
        <h2>Des projets déjà réalisés</h2>
        <p>Des idées devenues réalité grâce à nos makers.</p>
      </div>

      <div class="row">
        <%# Loop over every project that a maker has already completed %>
        <% @completed_projects.each do |project| %>
          <div class="col-md-4 mb-4">
            <%= link_to project_path(project), class: "home-project-link" do %>
              <div class="card-trip">
                <%# Status badge shown over the image %>
                <span class="card-status status-badge status-accepted"><%= project.status_label %></span>
                <%# Project image, or a placeholder if there is none %>
                <% if project.image.attached? %>
                  <%= image_tag project.image %>
                <% else %>
                  <img src="https://raw.githubusercontent.com/lewagon/fullstack-images/master/uikit/greece.jpg" />
                <% end %>
                <div class="card-trip-infos">
                  <div>
                    <%# Project title %>
                    <h2><%= project.title %></h2>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ===================================================================== %>
  <%# FINAL CALL TO ACTION                                                  %>
  <%# ===================================================================== %>
  <div class="home-cta">
    <h2>Votre idée mérite le bon savoir faire.</h2>
    <p>Publiez votre projet et entrez en contact avec des makers passionnés.</p>

    <%# Different button depending on the visitor: a dreamer creates a project,
        a maker browses the projects, a logged-out visitor signs up. %>
    <% if user_signed_in? && current_user.dreamer? %>
      <%= link_to "Créer un projet", new_project_path, class: "btn btn-primary" %>
    <% elsif user_signed_in? %>
      <%= link_to "Voir les projets", published_projects_path, class: "btn btn-primary" %>
    <% else %>
      <%= link_to "Commencer maintenant", new_user_registration_path(role: "dreamer"), class: "btn btn-primary" %>
    <% end %>
  </div>

  <%# For logged-in users, these sections are moved down here, at the very bottom %>
  <% if user_signed_in? %>
    <%= two_universes %>
    <%= how_it_works %>
  <% end %>

</div>
