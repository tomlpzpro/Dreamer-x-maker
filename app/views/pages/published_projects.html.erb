<div class="container my-5">

  <%# Link to go back to the homepage %>
  <%= link_to "← Retour à l'accueil", root_path, class: "btn btn-outline-secondary btn-sm mb-3" %>

  <%# Page header %>
  <div class="home-section-head">
    <h1>Les projets déjà publiés</h1>
    <p>Toutes les idées sur mesure qui cherchent leur artisan.</p>
  </div>

  <%= form_with url: published_projects_path, method: :get, data: { turbo_stream: true } do %>
<div class="row mb-4 g-3 align-items-center">
    <%# Left half: search + button %>
    <div class="col-md-6">
      <div class="input-group">
        <%= text_field_tag :query,
          params[:query],
          placeholder: "Rechercher un projet...",
          class: "form-control"
        %>
        <%= button_tag "Rechercher", type: "submit", class: "btn btn-secondary" %>
      </div>
    </div>
    <%# Right half: category %>
    <div class="col-md-6">
      <%= select_tag :category,
        options_for_select(
          [["Toutes les catégories", ""]] + User::SKILLS,
          params[:category]
        ),
        class: "form-select",
        onchange: "this.form.requestSubmit();"
      %>
    </div>
  </div>
  <% end %>
  <div id="published-projects-reset" class="mb-3">
    <% if params[:query].present? || params[:category].present? %>
      <%= link_to "Réinitialiser les filtres", published_projects_path, class: "btn btn-outline-secondary btn-sm" %>
    <% end %>
  </div>

  <%# Small text when there is no published project yet %>
  <div id="published-projects-list">
    <% if @projects.empty? %>
      <p class="dashboard-empty">Aucun projet publié pour le moment.</p>
    <% else %>
      <div class="row">
        <%# One card per published project %>
        <% @projects.each do |project| %>
          <div class="col-md-4 mb-4">
            <%# Wrapper kept relative so the maker action buttons can sit over the card %>
            <div class="project-card-wrapper">
              <%= link_to project_path(project), class: "home-project-link" do %>
                <div class="card-trip">
                  <%# Status badge shown over the image %>
                  <%= project_step_tag(project) %>
                  <%# Project image, or a placeholder if there is none %>
                  <% if project.image.attached? %>
                    <%= image_tag project.image %>
                  <% else %>
                    <%= image_tag "LOG0-V3.png", alt: "Pas encore de visuel" %>
                  <% end %>
                  <div class="card-trip-infos">
                    <div>
                      <h2><%= project.title %></h2>
                    </div>
                  </div>
                </div>
              <% end %>

              <%# A logged-in maker can match or dismiss a project he can still act on %>
              <% if user_signed_in? && current_user.maker? && project.open_for?(current_user) %>
                <%# Action buttons placed over the card, outside the link to avoid nested links %>
                <div class="project-card-actions">
                  <%# Match this project: creates the match and opens the discussion %>
                  <%= link_to "Matcher", match_project_path(project), data: { turbo_method: :post }, class: "card-action-btn card-action-match" %>
                  <%# Dismiss this project: it will no longer appear in my available projects %>
                  <%= link_to "Pas pour moi", dismiss_project_path(project), data: { turbo_method: :post }, class: "card-action-btn card-action-dismiss" %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

</div>
