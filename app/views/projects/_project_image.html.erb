<%# The big project visual. fun_bg_class gives it a fun, per-project backdrop
    color, shown around the image (kept at its original ratio). %>
<% if project.image.attached? %>
  <%= image_tag project.image, class: fun_bg_class(project) %>
<% else %>
  <%= image_tag "https://raw.githubusercontent.com/lewagon/fullstack-images/master/uikit/greece.jpg",
                alt: "Pas encore de visuel", class: fun_bg_class(project) %>
<% end %>
