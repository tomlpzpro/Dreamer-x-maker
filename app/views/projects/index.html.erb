<div class="container my-5">

  <%# Link to go back to the dashboard %>
  <%= link_to "← Retour au dashboard", dashboard_path, class: "btn btn-outline-secondary btn-sm mb-3" %>

  <%# Page header: title on the left, create button on the right %>
  <div class="dashboard-section-head">
    <h1>Mes projets</h1>
    <%# Only a dreamer can create a project %>
    <% if current_user.dreamer? %>
      <%= link_to "＋ Créer un projet", new_project_path, class: "btn btn-primary fw-bold text-white" %>
    <% end %>
  </div>

  <%# Show a small text when the dreamer has no project yet %>
  <% if @projects.empty? %>
    <p class="dashboard-empty">Vous n'avez pas encore de projet. Cliquez sur "Créer un projet" pour commencer !</p>
  <% else %>
    <%# One card per project %>
    <div class="row">
      <% @projects.each do |project| %>
        <div class="col-md-4 mb-4" id="<%= dom_id(project) %>">
          <%# Wrapper kept relative so the action buttons can sit over the card %>
          <div class="project-card-wrapper">
            <%# The whole card is a link to the project page %>
            <%= link_to project_path(project, from: "projects"), class: "home-project-link" do %>
              <div class="card-trip">
                <%# Status badge shown over the image %>
                <%= project_step_tag(project) %>
                <%# Project image, or a placeholder if there is none %>
                <% if project.image.attached? %>
                  <%= image_tag project.image %>
                <% else %>
                  <%= image_tag "LOG0-V3.png", alt: "Pas encore de visuel" %>
                <% end %>
                <div class="card-trip-infos">
                  <div>
                    <h2><%= project.title %></h2>
                  </div>
                </div>
              </div>
            <% end %>

            <%# Action buttons placed over the card, outside the link to avoid nested links %>
            <div class="project-card-actions">
              <%# The maker_project engaged on this project, if any %>
              <% engaged = project.maker_projects.find_by(status: MakerProject::ENGAGED_STATUSES) %>

              <% if engaged&.status == "accepted" && engaged.match_chat %>
                <%# Match accepted and project not realised yet: inform of a change
                    (the maker informs the dreamer, or the dreamer informs the maker) %>
                <%= link_to '<i class="fas fa-pencil"></i>'.html_safe, match_chat_path(engaged.match_chat), title: "Un changement ?", class: "card-action-btn card-action-inform" %>

              <% elsif current_user.role == "dreamer" && engaged.nil? %>
                <%# The dreamer's project is not taken yet: he can edit or delete it %>
                <%= link_to '<i class="fas fa-pencil"></i>'.html_safe, edit_project_path(project), title: "Modifier", class: "card-action-btn card-action-edit" %>
                <%= link_to '<i class="fas fa-xmark"></i>'.html_safe, project_path(project), title: "Supprimer",
                      data: { turbo_method: :delete, turbo_confirm: "Êtes-vous sûr de vouloir supprimer ce projet ?" },
                      class: "card-action-btn card-action-delete" %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

</div>
