<%= turbo_stream_from @llm_chat %>
<%= turbo_stream_from @project %>

<div class="container project-show my-5">

  <%# Back link: go back to the page the visitor came from.
      "dashboard" when opened from the dashboard, the projects list otherwise. %>
  <% if params[:from] == "dashboard" %>
    <%= link_to "← Retour au dashboard", dashboard_path, class: "btn btn-outline-secondary btn-sm mb-3" %>
  <% else %>
    <%= link_to "← Retour aux projets", projects_path, class: "btn btn-outline-secondary btn-sm mb-3" %>
  <% end %>

  <%# A dreamer visiting a project that is NOT theirs only sees a limited view:
      the title, the description, the "before" visual, the "after" photo and
      the note given to the maker. %>
  <% if current_user.dreamer? && current_user != @project.dreamer %>
    <% engaged = @project.engaged_maker_project %>

    <div class="project-public">
      <h1 class="project-public-title"><%= @project.title %></h1>

      <%# The note given to the maker, once the project is delivered %>
      <% if engaged&.rating.present? %>
        <div class="project-public-rating">
          <span class="rating-stars"><%= rating_stars(engaged.rating) %></span>
          <span class="rating-value"><%= engaged.rating %>/5</span>
          <span class="rating-by">réalisé par
            <%= link_to engaged.maker.username, maker_path(engaged.maker), class: "rating-by-link" %>
          </span>
        </div>
      <% end %>

      <p class="project-public-desc"><%= @project.description %></p>

      <%# "Before" visual and "After" photo (the latter only if delivered) %>
      <div class="project-public-photos">
        <figure class="project-public-photo">
          <figcaption>Avant</figcaption>
          <%= render "projects/project_image", project: @project %>
        </figure>

        <% if engaged&.delivery_photo&.attached? %>
          <figure class="project-public-photo">
            <figcaption>Après</figcaption>
            <%= image_tag engaged.delivery_photo %>
          </figure>
        <% end %>
      </div>
    </div>

  <% else %>

  <%# Maker actions at the top of the page: match this project or pass on it %>
  <% if current_user.maker? && @project.open_for?(current_user) %>
    <div class="project-match">
      <%# Small question to make the choice clear %>
      <p class="project-match-question">Ce projet vous inspire&nbsp;?</p>
      <div class="project-match-bar">
        <%# Matcher: blue full-screen flash, then open the chat with the dreamer %>
        <%= button_to match_project_path(@project),
              class: "card-action-btn card-action-match",
              form: { data: { controller: "flash-navigate", flash_navigate_color_value: "blue" } },
              data: { action: "click->flash-navigate#go" } do %>
          <span>Matcher</span>
        <% end %>
        <%# Pas pour moi: orange full-screen flash, then go back to the previous page %>
        <%= button_to dismiss_project_path(@project, back: request.referer),
              class: "card-action-btn card-action-dismiss",
              form: { data: { controller: "flash-navigate", flash_navigate_color_value: "orange" } },
              data: { action: "click->flash-navigate#go" } do %>
          <span>Pas pour moi</span>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# === Header: title (+ owner buttons) on the left, maker actions on the right === %>
  <div class="project-header">

    <%# Title with the owner's edit/delete buttons right next to it %>
    <div class="project-header-title">
      <h1><%= @project.title %></h1>
      <% if current_user == @project.dreamer %>
        <div class="project-header-actions">
          <%= link_to '<i class="fas fa-pencil"></i>'.html_safe, edit_project_path(@project), title: "Modifier", class: "card-action-btn card-action-edit" %>
          <%= link_to '<i class="fas fa-trash"></i>'.html_safe, project_path(@project), title: "Supprimer",
                data: { turbo_method: :delete, turbo_confirm: "Êtes-vous sûr de vouloir supprimer ce projet ?" },
                class: "card-action-btn card-action-delete" %>
        </div>
      <% end %>
    </div>

    <%# Right side: maker actions %>
    <div class="project-header-status">
      <%# This maker's application on the project (nil for the dreamer) %>
      <% my_maker_project = @project.maker_projects.find { |mp| mp.maker_id == current_user.id } %>
      <% if my_maker_project %>
        <%# Maker action: tell the dreamer the project is realised %>
        <%= render "maker_projects/progress_buttons",
                   maker_project: my_maker_project,
                   made_label: "Informer #{@project.dreamer.username} que son projet est terminé !" %>
      <% end %>

      <%# Dreamer action: confirm reception (only shown to the dreamer when "made") %>
      <% if @project.engaged_maker_project %>
        <%= render "maker_projects/receive_button", maker_project: @project.engaged_maker_project %>
      <% end %>
    </div>
  </div>

  <div class="row">

    <%# === Left column: the visual + all the project info === %>
    <div class="col-md-7">

      <%# The project visual (image), or a placeholder if there is none %>
      <div id="generate-project-image" class="project-image">
        <div id="loader-container" style="display: none;">
           <!-- style="display: none;" -->
          <%= render "shared/loader_modal" %>
        </div>
        <%= render "projects/project_image", project: @project %>
      </div>
      <%# Description in its own card %>
      <div class="project-description">
        <h2>Description</h2>
        <p><%= @project.description %></p>
      </div>

      <%# Key facts shown as small boxes with an icon each %>
      <div class="info-grid">
        <div class="info-box">
          <i class="fas fa-coins"></i>
          <div>
            <div class="info-label">Budget</div>
            <div class="info-value"><%= @project.budget %> €</div>
          </div>
        </div>

        <div class="info-box">
          <i class="fas fa-calendar-day"></i>
          <div>
            <div class="info-label">Échéance</div>
            <div class="info-value"><%= @project.deadline %></div>
          </div>
        </div>

        <div class="info-box">
          <i class="fas fa-user"></i>
          <div>
            <div class="info-label">Créé par</div>
            <div class="info-value"><%= @project.dreamer.username %></div>
          </div>
        </div>

        <div class="info-box">
          <i class="fas fa-clock"></i>
          <div>
            <div class="info-label">Créé le</div>
            <div class="info-value"><%= @project.created_at.strftime("%d/%m/%Y") %></div>
          </div>
        </div>
      </div>
    </div>

    <%# === Right column: the timeline + the applications === %>
    <div class="col-md-5">

      <%# Timeline of the project steps.
          Past steps are validated (orange dot with a check),
          future steps are shown but not validated (empty dot). %>
      <div class="timeline-card">
        <h2>Étapes du projet</h2>

        <ul class="timeline">

          <%# Step 1: the project was created (always done) %>
          <li class="timeline-step is-done">
            <div class="timeline-title">Projet créé</div>
            <div class="timeline-date"><%= @project.created_at.strftime("%d/%m/%Y") %></div>
          </li>

          <%# Step 2: a visual was made (done only if an image is attached) %>
          <li class="timeline-step <%= @project.image.attached? ? 'is-done' : 'is-todo' %>">
            <div class="timeline-title">Visuel réalisé</div>
            <div class="timeline-date">
              <%= @project.image.attached? ? "Une image est associée au projet" : "À venir : générez ou ajoutez un visuel" %>
            </div>
          </li>

          <%# Step 3: the project is published (always done here) %>
          <li class="timeline-step is-done">
            <div class="timeline-title">Projet publié</div>
            <div class="timeline-date">Visible par les makers</div>
          </li>

          <%# Step 4: a maker was matched (done only if matched) %>
          <li class="timeline-step <%= @project.matched? ? 'is-done' : 'is-todo' %>">
            <div class="timeline-title">Match trouvé</div>
            <div class="timeline-date">
              <%= @project.matched? ? "Un maker a été accepté" : "À venir : en attente d'un maker" %>
            </div>
          </li>

          <%# The status of the engaged maker on this project (nil if none yet) %>
          <% engaged_status = @project.engaged_maker_project&.status %>

          <%# Step 5: the project was realised by the maker (made, then delivered) %>
          <li class="timeline-step <%= %w[made delivered].include?(engaged_status) ? 'is-done' : 'is-todo' %>">
            <div class="timeline-title">Projet réalisé</div>
            <div class="timeline-date">
              <%= %w[made delivered].include?(engaged_status) ? "Le maker a terminé la réalisation" : "À venir : réalisation par le maker" %>
            </div>
          </li>

          <%# Step 6: the project was delivered and received by the dreamer %>
          <li class="timeline-step <%= engaged_status == 'delivered' ? 'is-done' : 'is-todo' %>">
            <div class="timeline-title">Projet livré</div>
            <div class="timeline-date">
              <%= engaged_status == "delivered" ? "Le projet a été reçu par le dreamer" : "À venir : réception par le dreamer" %>
            </div>
          </li>

        </ul>
      </div>

      <%# The makers who applied to this project %>
      <div class="candidatures-card">
        <h2>Demandes de match</h2>

        <% if @maker_projects.empty? %>
          <p class="text-muted">Aucun maker n'a encore postulé.</p>
        <% else %>
          <% @maker_projects.each do |mp| %>
            <div class="candidature-row">

              <%# Top line: maker photo + name (left) and "go to discussion" (right) %>
              <div class="candidature-head">
                <div class="candidature-person">
                  <%# Profile picture of the maker (or a placeholder) %>
                  <% if mp.maker.profile_picture_url.present? %>
                    <%= image_tag mp.maker.profile_picture_url, class: "candidature-avatar", alt: mp.maker.username %>
                  <% else %>
                    <%= image_tag "https://kitt.lewagon.com/placeholder/users/ssaunier", class: "candidature-avatar", alt: mp.maker.username %>
                  <% end %>
                  <%# Maker name links to their public profile (their creations) %>
                  <%= link_to mp.maker.username, maker_path(mp.maker), class: "match-title maker-link" %>
                </div>

                <%# "Aller à la discussion" aligned with the name, on the right %>
                <% if mp.match_chat.present? %>
                  <%= link_to "Aller à la discussion", match_chat_path(mp.match_chat), class: "btn btn-outline-secondary btn-sm" %>
                <% else %>
                  <span class="candidature-nochat">Pas encore de discussion</span>
                <% end %>
              </div>

              <%# Status badge / accept-reject buttons, below the name %>
              <div class="candidature-actions">
                <%# Projet livré par le maker %>
                <% if mp.status == "delivered" %>
                  <span class="status-badge status-delivered">Livré</span>

                  <%# Projet réalisé par le maker (pas encore livré) %>
                <% elsif mp.status == "made" %>
                  <span class="status-badge status-made">Réalisé</span>

                  <%# Si la demande de match dy maker (candidature) est acceptée, on affiche juste le badge vert %>
                <% elsif mp.status == "accepted" %>
                  <span class="status-badge status-accepted">Accepté</span>

                  <%# Si elle est refusée, on affiche juste le badge rouge %>
                <% elsif mp.status == "rejected" %>
                  <span class="status-badge status-rejected">Refusé</span>

                  <%# Si elle est en attente ET que c'est le dreamer qui regarde la page %>
                  <%# (un maker ne doit pas voir ces boutons sur la page d'un autre projet) %>
                <% elsif current_user == @project.dreamer %>

                  <%# Bouton Accepter : envoie un PATCH à approve_project_path %>
                  <%# params: passe l'id de la candidature au contrôleur %>
                  <%= button_to "Accepter",
                    approve_project_path(@project),
                    method: :patch,
                    params: { maker_project_id: mp.id },
                    class: "btn btn-primary btn-sm" %>
                  <%# Bouton Refuser : envoie un PATCH à reject_project_path %>
                  <%= button_to "Refuser",
                    reject_project_path(@project),
                    method: :patch,
                    params: { maker_project_id: mp.id },
                    class: "btn btn-reject btn-sm" %>
                  <%# Si c'est le maker lui-même qui regarde, on lui montre juste "En attente" %>
                <% else %>
                  <span class="status-badge status-pending">En attente</span>

                <% end %>
              </div>

            </div>
          <% end %>
        <% end %>
      </div>

    </div>
  </div>

  <%# AI chat to generate the visual: only for the owner (dreamer) and if it exists %>
  <% if @llm_chat.present? && current_user == @project.dreamer %>
    <div class="container my-5">

      <%# Page title %>
      <h1 class="mb-4">AI chat</h1>

      <%# Listen for new messages broadcast by the model (user + AI reply),so they appear live without reloading the page. %>


      <%# The box that holds all the messages %>
      <div class="chat-box mb-4">

        <%# Every message; new ones are appended here by Turbo Stream %>
        <div id="messages">
          <%# Placeholder shown only while the chat is empty (hidden in CSS once
              a message exists, so it disappears as soon as one is appended) %>
          <p class="chat-empty text-center text-muted my-5">Demarrez la conversation avec le ChatBot</p>
          <%= render @llm_messages %>
        </div>

      </div>


      <div id="generate-visual-button" data-controller="visual-loading">
        <% if @llm_messages.count { |m| m.role == "user" } >= 3 %>
          <%= button_to "Générer mon visuel", generate_visual_llm_chat_path(@llm_chat),
              method: :post,
              class: "btn btn-dark mb-3",
              form: { data: { action: "submit->visual-loading#showLoading" } } %>
        <% end %>
      </div>

      <%= render "llm_messages/form", llm_chat: @llm_chat, llm_message: @llm_message %>

    </div>
  <% end %>

  <% end %>

</div>
