<%# Main navbar. "sticky-top" keeps it visible at the top while scrolling.
    Three parts: hamburger menu (left), brand (center), account (right). %>
<nav class="navbar navbar-lewagon sticky-top">
  <div class="container-fluid navbar-grid">

    <%# === Left: hamburger menu with the different parts of the site === %>
    <div class="dropdown">
      <%# The hamburger button (☰) that opens the menu %>
      <button class="navbar-toggler" type="button" data-bs-toggle="dropdown"
              aria-expanded="false" aria-label="Ouvrir le menu">
        <span class="navbar-toggler-icon"></span>
      </button>
      <%# The list of site sections %>
      <ul class="dropdown-menu">
        <li><%= link_to "Accueil", root_path, class: "dropdown-item" %></li>
        <%# Dashboard is shown above Projets, only when the user is logged in %>
        <% if user_signed_in? %>
          <li><%= link_to "Dashboard", dashboard_path, class: "dropdown-item" %></li>
        <% end %>
        <li><%= link_to "Projets", projects_path, class: "dropdown-item" %></li>
        <%# Discussions also needs the user to be logged in %>
        <% if user_signed_in? %>
          <li><%= link_to "Discussions", match_chats_path, class: "dropdown-item" %></li>
        <% end %>
      </ul>
    </div>

    <%# === Center: brand name "Dreamer x Maker" === %>
    <%= link_to root_path, class: "navbar-brand navbar-brand-text" do %>
      <span class="word-dreamer">Dreamer</span>
      <span class="word-x">x</span>
      <span class="word-maker">Maker</span>
    <% end %>

    <%# === Right: account area === %>
    <div class="navbar-account">
      <% if user_signed_in? %>

        <%# Subscribe to this user's stream so the notif badge updates live %>
        <%= turbo_stream_from current_user %>

        <%# Discussions shortcut with the unread-messages badge over it %>
        <%= link_to match_chats_path, class: "navbar-notif", title: "Mes discussions" do %>
          <%# Envelope colored by role: orange for a dreamer, blue for a maker %>
          <i class="fas fa-envelope navbar-notif-icon <%= current_user.dreamer? ? 'is-dreamer' : 'is-maker' %>"></i>
          <%# The badge disappears once on the discussions page (i.e. once the
              user clicked the envelope); elsewhere it shows the unread count. %>
          <% unless current_page?(match_chats_path) %>
            <%= render "shared/notif_badge", user: current_user %>
          <% end %>
        <% end %>

        <%# Notifications bell: the actions to take (applications, matches...) %>
        <%= render "shared/notifications_bell" %>

        <%# Logged in: avatar + first name that open a dropdown menu %>
        <div class="dropdown">
          <a href="#" class="navbar-avatar-link dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
            <%# The user's photo, or a placeholder if there is none %>
            <% if current_user.profile_picture_url.present? %>
              <%= image_tag current_user.profile_picture_url, class: "avatar", alt: "profil" %>
            <% else %>
              <%= image_tag "https://kitt.lewagon.com/placeholder/users/ssaunier", class: "avatar", alt: "profil" %>
            <% end %>
            <%# Show the username next to the photo (hidden on very small screens) %>
            <span class="navbar-username"><%= current_user.username %></span>
          </a>
          <%# Menu aligned to the right edge %>
          <ul class="dropdown-menu dropdown-menu-end">
            <li><%= link_to "Profil", profile_path, class: "dropdown-item" %></li>
            <li><%= link_to "Mon dashboard", dashboard_path, class: "dropdown-item" %></li>
            <li><hr class="dropdown-divider"></li>
            <li><%= link_to "Déconnexion", destroy_user_session_path, data: { turbo_method: :delete }, class: "dropdown-item" %></li>
          </ul>
        </div>

      <% else %>

        <%# Logged out: login link + sign up button %>
        <%= link_to "Connexion", new_user_session_path, class: "btn btn-outline-secondary btn-sm me-2" %>
        <%= link_to "Inscription", new_user_registration_path, class: "btn btn-primary btn-sm" %>

      <% end %>
    </div>

  </div>
</nav>
