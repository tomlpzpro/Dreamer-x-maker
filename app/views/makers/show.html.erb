<div class="container my-5">

  <%# Link to go back to the previous page %>
  <%= link_to "← Retour", :back, class: "btn btn-outline-secondary btn-sm mb-3" %>

  <%# === Hero header (turquoise = the maker side) === %>
  <div class="maker-hero">

    <%# The maker's photo %>
    <div class="maker-hero-photo">
      <% if @maker.profile_picture_url.present? %>
        <%= image_tag @maker.profile_picture_url, alt: @maker.username %>
      <% else %>
        <%= image_tag "https://kitt.lewagon.com/placeholder/users/ssaunier", alt: @maker.username %>
      <% end %>
    </div>

    <%# The maker's name and skills %>
    <div class="maker-hero-info">
      <p class="maker-hero-label">Maker · La main</p>
      <h1><%= @maker.username %></h1>

      <%# Skills shown as small chips (the skills string is split on commas) %>
      <% if @maker.skills.present? %>
        <div class="maker-skills">
          <% @maker.skills.split(",").each do |skill| %>
            <span class="maker-skill"><%= skill.strip %></span>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <%# === Delivered creations === %>
  <div class="maker-creations">
    <div class="maker-creations-head">
      <h2>Dernières créations livrées</h2>
      <span class="maker-creations-count"><%= @creations.count %> réalisation(s)</span>
    </div>

    <% if @creations.empty? %>
      <p class="text-muted">Ce maker n'a pas encore de création livrée.</p>
    <% else %>
      <div class="row">
        <% @creations.each do |project| %>
          <div class="col-md-4 mb-4">
            <%= link_to project_path(project), class: "home-project-link" do %>
              <div class="card-trip">
                <%# Status badge shown over the image %>
                <span class="card-status status-badge <%= project.matched? ? 'status-accepted' : 'status-pending' %>"><%= project.status_label %></span>
                <%# Project image, or a placeholder if there is none %>
                <% if project.image.attached? %>
                  <%= image_tag project.image %>
                <% else %>
                  <img src="https://raw.githubusercontent.com/lewagon/fullstack-images/master/uikit/greece.jpg" />
                <% end %>
                <div class="card-trip-infos">
                  <div>
                    <h2><%= project.title %></h2>
                    <p><%= project.description %></p>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

</div>
