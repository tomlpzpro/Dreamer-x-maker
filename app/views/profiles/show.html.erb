<div class="container my-5">

  <%# === Hero header: colored by role (orange dreamer / turquoise maker) === %>
  <div class="profile-hero <%= @user.maker? ? 'is-maker' : 'is-dreamer' %>">

    <%# Profile picture, or a placeholder if there is none %>
    <div class="profile-hero-photo">
      <% if @user.profile_picture_url.present? %>
        <%= image_tag @user.profile_picture_url, alt: "photo de profil" %>
      <% else %>
        <%= image_tag "https://kitt.lewagon.com/placeholder/users/ssaunier", alt: "photo de profil" %>
      <% end %>
    </div>

    <%# Role label + name %>
    <div class="profile-hero-info">
      <p class="profile-hero-label"><%= @user.maker? ? "Maker · La main" : "Dreamer · L'idée" %></p>
      <h1><%= @user.username %></h1>
    </div>

    <%# Button to edit the profile %>
    <%= link_to "Modifier mon profil", edit_profile_path, class: "btn btn-light" %>
  </div>

  <%# === Information shown as small boxes with an icon each === %>
  <div class="profile-details">
    <h2 class="mb-4">Mes informations</h2>

    <div class="info-grid">
      <div class="info-box">
        <i class="fas fa-envelope"></i>
        <div>
          <div class="info-label">Email</div>
          <div class="info-value"><%= @user.email %></div>
        </div>
      </div>

      <div class="info-box">
        <i class="fas fa-phone"></i>
        <div>
          <div class="info-label">Téléphone</div>
          <div class="info-value"><%= @user.phone_number.presence || "—" %></div>
        </div>
      </div>

      <div class="info-box">
        <i class="fas fa-location-dot"></i>
        <div>
          <div class="info-label">Adresse</div>
          <div class="info-value"><%= @user.adresse.presence || "—" %></div>
        </div>
      </div>

      <%# Skills only make sense for makers %>
      <% if @user.skills.present? %>
        <div class="info-box">
          <i class="fas fa-screwdriver-wrench"></i>
          <div>
            <div class="info-label">Compétences</div>
            <div class="info-value"><%= @user.skills %></div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

</div>
