<div class="container my-5">

  <%# Page title %>
  <h1 class="mb-4">My profile</h1>

  <div class="profile-card">

    <%# Profile picture, or a placeholder if there is none %>
    <% if @user.profile_picture_url.present? %>
      <%= image_tag @user.profile_picture_url, class: "profile-photo", alt: "profile photo" %>
    <% else %>
      <%= image_tag "https://kitt.lewagon.com/placeholder/users/ssaunier", class: "profile-photo", alt: "profile photo" %>
    <% end %>

    <%# The user name and role %>
    <h2 class="mt-3"><%= @user.username %></h2>
    <p class="text-muted"><%= @user.role&.capitalize %></p>

    <%# All the user information, line by line %>
    <ul class="list-group text-start mt-4">
      <li class="list-group-item"><strong>Email:</strong> <%= @user.email %></li>
      <li class="list-group-item"><strong>Phone:</strong> <%= @user.phone_number %></li>
      <li class="list-group-item"><strong>Address:</strong> <%= @user.adresse %></li>
      <%# Skills only make sense for makers %>
      <% if @user.skills.present? %>
        <li class="list-group-item"><strong>Skills:</strong> <%= @user.skills %></li>
      <% end %>
    </ul>

    <%# Button to edit the profile %>
    <%= link_to "Edit profile", edit_profile_path, class: "btn btn-primary mt-4" %>

  </div>

</div>
