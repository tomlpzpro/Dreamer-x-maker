<div class="container my-5">

  <h1 class="mb-4">Discute avec le ChatBot pour générer un visuel</h1>

  <div class="chat-box mb-4">

    <% if @llm_messages.empty? %>
      <p class="text-center text-muted my-5">Démarre la discussion</p>
    <% end %>

    <% @llm_messages.each do |message| %>
      <div class="chat-message <%= message.role == "user" ? "from-user" : "from-ai" %>">
        <div class="chat-bubble">
          <%= message.content %>
        </div>
      </div>
    <% end %>

    <% if @llm_chat.project.image.attached? %>
      <div class="chat-message from-ai">
        <div class="chat-bubble">
          <%= image_tag @llm_chat.project.image, class: "img-fluid rounded" %>
        </div>
      </div>
    <% end %>

  </div>

  <% if @llm_messages.last&.role == "assistant" && !@llm_chat.project.image.attached? %>
    <%= button_to "Générer mon visuel ✨", generer_visuel_ai_chat_path(@llm_chat), method: :post, class: "btn btn-dark mb-3" %>
  <% end %>

  <%= form_with model: @llm_message, url: messages_ai_chat_path(@llm_chat) do |form| %>
    <div class="d-flex gap-2">
      <%= form.text_field :content, class: "form-control", placeholder: "Écris ton message..." %>
      <%= form.submit "Envoyer", class: "btn btn-primary" %>
    </div>
  <% end %>

</div>
