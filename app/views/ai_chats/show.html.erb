<div class="container my-5">

  <%# Page title %>
  <h1 class="mb-4">AI chat</h1>

  <%# The box that holds all the messages %>
  <div class="chat-box mb-4">

    <%# Show a small text when there is no message yet %>
    <% if @llm_messages.empty? %>
      <p class="text-center text-muted my-5">No message yet. Start the conversation below!</p>
    <% end %>

    <%# Loop over every message of this chat %>
    <% @llm_messages.each do |message| %>
      <%# "user" messages go on the right, the others (AI) go on the left %>
      <div class="chat-message <%= message.role == "user" ? "from-user" : "from-ai" %>">
        <div class="chat-bubble">
          <%= message.content %>
        </div>
      </div>
    <% end %>

  </div>

  <%= button_to "Générer mon visuel", generer_visuel_ai_chat_path(@llm_chat), method: :post, class: "btn btn-dark mb-3" %>
  <%# Form to write and send a new message %>
  <%= form_with model: @llm_message, url: messages_ai_chat_path(@llm_chat) do |form| %>
    <div class="d-flex gap-2">
      <%= form.text_field :content, class: "form-control", placeholder: "Write your message..." %>
      <%= form.submit "Send", class: "btn btn-primary" %>
    </div>
  <% end %>

</div>
