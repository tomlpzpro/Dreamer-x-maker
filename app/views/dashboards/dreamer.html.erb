<div class="container dashboard">

  <%# ===================================================================== %>
  <%# WELCOME HEADER                                                        %>
  <%# ===================================================================== %>
  <div class="dashboard-header is-dreamer">
    <div>
      <h1>Bonjour <%= current_user.username %> 👋</h1>
      <p class="dashboard-subtitle">Voici un aperçu de vos projets et de vos échanges.</p>
    </div>
    <%= link_to "＋ Créer un projet", new_project_path, class: "btn btn-primary" %>
  </div>

  <%# ===================================================================== %>
  <%# STAT CARDS                                                            %>
  <%# ===================================================================== %>
  <div class="dashboard-stats">
    <div class="stat-card">
      <div class="stat-number"><%= current_user.projects.count %></div>
      <div class="stat-label">Projets</div>
    </div>
    <div class="stat-card">
      <div class="stat-number"><%= @maker_projects.count %></div>
      <div class="stat-label">Matchs</div>
    </div>
    <div class="stat-card">
      <div class="stat-number"><%= @match_chats.count %></div>
      <div class="stat-label">Discussions</div>
    </div>
  </div>

  <%# ===================================================================== %>
  <%# MY PROJECTS (preview)                                                 %>
  <%# ===================================================================== %>
  <div class="dashboard-section">
    <div class="dashboard-section-head">
      <h2>Mes projets</h2>
      <%= link_to "Voir tous mes projets", projects_path %>
    </div>

    <% if @projects.empty? %>
      <p class="dashboard-empty">Vous n'avez pas encore de projet.</p>
    <% else %>
      <div class="row">
        <% @projects.each do |project| %>
          <div class="col-md-3 mb-4">
            <%= link_to project_path(project), class: "home-project-link" do %>
              <div class="card-trip">
                <%# Status badge shown over the image %>
                <span class="card-status status-badge <%= project.matched? ? 'status-accepted' : 'status-pending' %>"><%= project.status_label %></span>
                <%# Project image, or a placeholder if there is none %>
                <% if project.image.attached? %>
                  <%= image_tag project.image %>
                <% else %>
                  <img src="https://raw.githubusercontent.com/lewagon/fullstack-images/master/uikit/greece.jpg" />
                <% end %>
                <div class="card-trip-infos">
                  <div>
                    <h2><%= project.title %></h2>
                    <p><%= project.description %></p>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# ===================================================================== %>
  <%# MY MATCHES (makers who applied to my projects)                       %>
  <%# ===================================================================== %>
  <div class="dashboard-section">
    <div class="dashboard-section-head">
      <h2>Mes matchs</h2>
    </div>

    <% if @maker_projects.empty? %>
      <p class="dashboard-empty">Aucun maker n'a encore postulé à vos projets.</p>
    <% else %>
      <% @maker_projects.each do |mp| %>
        <%# The whole row is a link to the related project page %>
        <%= link_to project_path(mp.project), class: "match-row" do %>

          <%# Maker photo + project title and maker name (left side) %>
          <div class="match-person">
            <% if mp.maker.profile_picture_url.present? %>
              <%= image_tag mp.maker.profile_picture_url, class: "match-avatar", alt: mp.maker.username %>
            <% else %>
              <%= image_tag "https://kitt.lewagon.com/placeholder/users/ssaunier", class: "match-avatar", alt: mp.maker.username %>
            <% end %>
            <span class="match-title"><%= mp.project.title %> — <%= mp.maker.username %></span>
          </div>

          <%# Colored badge depending on the status of the application %>
          <% if mp.status == "accepted" %>
            <span class="status-badge status-accepted">Match !</span>
          <% elsif mp.status == "rejected" %>
            <span class="status-badge status-rejected">Refusé</span>
          <% else %>
            <span class="status-badge status-pending">En attente</span>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  </div>

  <%# ===================================================================== %>
  <%# MY DISCUSSIONS                                                        %>
  <%# ===================================================================== %>
  <div class="dashboard-section">
    <div class="dashboard-section-head">
      <h2>Mes discussions</h2>
      <%= link_to "Voir toutes mes discussions", match_chats_path %>
    </div>

    <% if @match_chats.empty? %>
      <p class="dashboard-empty">Vous n'avez pas encore de discussion.</p>
    <% else %>
      <% @match_chats.each do |chat| %>
        <%# For a dreamer, the other person is the maker %>
        <% other = chat.maker_project.maker %>
        <%= link_to match_chat_path(chat), class: "discussion-row" do %>
          <%# Profile picture of the other person (or a placeholder) %>
          <% if other.profile_picture_url.present? %>
            <%= image_tag other.profile_picture_url, class: "discussion-avatar", alt: other.username %>
          <% else %>
            <%= image_tag "https://kitt.lewagon.com/placeholder/users/ssaunier", class: "discussion-avatar", alt: other.username %>
          <% end %>
          <div class="discussion-info">
            <div class="discussion-name"><%= other.username %></div>
            <div class="discussion-project"><%= chat.maker_project.project.title %></div>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>

</div>
