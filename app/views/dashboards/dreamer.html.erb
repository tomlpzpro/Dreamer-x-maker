<div class="container" id="dreamer-dashboard">

  <h1>Mon Tableau de Bord Dreamer ✨</h1>

  <div>
    <%= link_to "Créer un nouveau projet", new_project_path, class: "btn btn-primary mx-5" %>
  </div>

  <%# -----Mes MATCHS------ %>
  <div>
    <h2>Mes matchs !</h2>
    <h3>Où en sont mes projets ?</h3>

    <div>
      <% @maker_projects.each do |mp| %>
        <div>
          <h5><%= mp.project.title %></h5>

          <% if mp.status == "accepted" %>
            <span>Match !</span>
          <% else %>
            <span>En attente de match</span>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <%# -----Mes PROJETS------ %>
  <div>
    <h2>Mes Projets</h2>

    <div class="row">
      <% @projects.each do |project| %>
        <%= link_to project_path(project) do %>
          <div class="card-trip">
            <%# Image du projet si elle existe, sinon image par défaut %>
            <% if project.respond_to?(:image) && project.image.attached? %>
              <%= image_tag project.image %>
            <% else %>
              <img src="https://raw.githubusercontent.com/lewagon/fullstack-images/master/uikit/greece.jpg" />
            <% end %>

            <div class="card-trip-infos">
              <div>
                <h2><%= project.title %></h2>
                <p><%= project.description %></p>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <%= link_to "Voir plus ...", projects_path %>
  </div>

  <%# -----Mes DISCUSSIONS------ %>
  <div>
    <h2>Mes Discussions</h2>

    <% @match_chats.each do |chat| %>
      <%= link_to match_chat_path(chat) do %>
        <div>
          <span>Chat avec <%= chat.maker_project.maker.username %></span>
        </div>
      <% end %>
    <% end %>
  </div>

</div>
