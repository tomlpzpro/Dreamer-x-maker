<div class="container dashboard">

  <%# ===================================================================== %>
  <%# WELCOME HEADER (turquoise for the maker side)                         %>
  <%# ===================================================================== %>
  <div class="dashboard-header is-maker">
    <div>
      <h1>Bonjour <%= current_user.username %> 👋</h1>
      <p class="dashboard-subtitle">Voici vos candidatures et vos échanges avec les dreamers.</p>
    </div>
    <%= link_to "Découvrir les projets", projects_path, class: "btn btn-secondary" %>
  </div>

  <%# ===================================================================== %>
  <%# STAT CARDS                                                            %>
  <%# ===================================================================== %>
  <div class="dashboard-stats">
    <div class="stat-card">
      <div class="stat-number"><%= @maker_projects.count %></div>
      <div class="stat-label">Candidatures</div>
    </div>
    <div class="stat-card">
      <%# Count only the applications that were accepted %>
      <div class="stat-number"><%= @maker_projects.count { |mp| mp.status == "accepted" } %></div>
      <div class="stat-label">Acceptées</div>
    </div>
    <div class="stat-card">
      <div class="stat-number"><%= @match_chats.count %></div>
      <div class="stat-label">Discussions</div>
    </div>
  </div>

  <%# ===================================================================== %>
  <%# MY APPLICATIONS (projects I applied to)                              %>
  <%# ===================================================================== %>
  <div class="dashboard-section">
    <div class="dashboard-section-head">
      <h2>Mes candidatures</h2>
    </div>

    <% if @maker_projects.empty? %>
      <p class="dashboard-empty">Vous n'avez pas encore postulé à un projet.</p>
    <% else %>
      <% @maker_projects.each do |mp| %>
        <div class="match-row">
          <span class="match-title"><%= mp.project.title %></span>

          <%# Colored badge depending on the status of my application %>
          <% if mp.status == "accepted" %>
            <span class="status-badge status-accepted">Acceptée</span>
          <% elsif mp.status == "rejected" %>
            <span class="status-badge status-rejected">Refusée</span>
          <% else %>
            <span class="status-badge status-pending">En attente</span>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>

  <%# ===================================================================== %>
  <%# MY DISCUSSIONS                                                        %>
  <%# ===================================================================== %>
  <div class="dashboard-section">
    <div class="dashboard-section-head">
      <h2>Mes discussions</h2>
      <%= link_to "Voir toutes mes discussions", match_chats_path %>
    </div>

    <% if @match_chats.empty? %>
      <p class="dashboard-empty">Vous n'avez pas encore de discussion.</p>
    <% else %>
      <% @match_chats.each do |chat| %>
        <%# For a maker, the other person is the project's dreamer %>
        <% other = chat.maker_project.project.dreamer %>
        <%= link_to match_chat_path(chat), class: "discussion-row" do %>
          <%# Profile picture of the other person (or a placeholder) %>
          <% if other.profile_picture_url.present? %>
            <%= image_tag other.profile_picture_url, class: "discussion-avatar", alt: other.username %>
          <% else %>
            <%= image_tag "https://kitt.lewagon.com/placeholder/users/ssaunier", class: "discussion-avatar", alt: other.username %>
          <% end %>
          <div class="discussion-info">
            <div class="discussion-name"><%= other.username %></div>
            <div class="discussion-project"><%= chat.maker_project.project.title %></div>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>

</div>
