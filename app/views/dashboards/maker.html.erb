<div class="container dashboard">

  <%# ===================================================================== %>
  <%# WELCOME HEADER                                                        %>
  <%# ===================================================================== %>
  <div class="dashboard-header is-maker">
    <div>
      <h1>Bonjour <%= current_user.username %> 👋</h1>
      <p class="dashboard-subtitle">Voici un aperçu de vos matchs et de vos échanges.</p>
    </div>
  </div>

  <%# ===================================================================== %>
  <%# STAT CARDS                                                            %>
  <%# ===================================================================== %>
  <div class="dashboard-stats">
    <div class="stat-card">
      <div class="stat-number"><%= @maker_projects.count %></div>
      <div class="stat-label">Matchs</div>
    </div>
    <div class="stat-card">
      <div class="stat-number"><%= @match_chats.count %></div>
      <div class="stat-label">Discussions</div>
    </div>
    <div class="stat-card">
      <div class="stat-number"><%= @current_projects.count %></div>
      <div class="stat-label">Projets en cours</div>
    </div>
    <div class="stat-card">
      <div class="stat-number"><%= @open_projects.count %></div>
      <div class="stat-label">Projets disponibles</div>
    </div>
  </div>

  <%# ===================================================================== %>
  <%# MY CURRENT PROJECTS (projects where I have been accepted)             %>
  <%# ===================================================================== %>
  <div class="dashboard-section">
    <div class="dashboard-section-head">
      <h2>Mes projets en cours</h2>
    </div>

    <% if @current_projects.empty? %>
      <p class="dashboard-empty">Vous n'avez pas de projet en cours pour le moment.</p>
    <% else %>
      <div class="row">
        <% @current_projects.each do |project| %>
          <div class="col-md-3 mb-4">
            <%# Wrapper kept relative so the action button can sit over the card %>
            <div class="project-card-wrapper">
              <%# Link to the project details page %>
              <%= link_to project_path(project, from: "dashboard"), class: "home-project-link" do %>
                <div class="card-trip">
                  <%# Status badge shown over the image %>
                  <span class="card-status status-badge <%= project.matched? ? 'status-accepted' : 'status-pending' %>"><%= project.status_label %></span>
                  <%# Project image, or a placeholder if there is none %>
                  <% if project.image.attached? %>
                    <%= image_tag project.image %>
                  <% else %>
                    <img src="https://raw.githubusercontent.com/lewagon/fullstack-images/master/uikit/greece.jpg" />
                  <% end %>
                  <div class="card-trip-infos">
                    <div>
                      <%# Project title %>
                      <h2><%= project.title %></h2>
                    </div>
                  </div>
                </div>
              <% end %>
              <%# Action button placed over the card, outside the link to avoid nested links %>
              <div class="project-card-actions">
                <%# Find this project's engaged maker_project and its chat %>
                <% accepted_maker_project = project.maker_projects.find_by(status: MakerProject::ENGAGED_STATUSES) %>
                <% chat = accepted_maker_project&.match_chat %>
                <%# Button leading to the chat with the dreamer to warn him of a change %>
                <% if chat %>
                  <%= link_to "💬 Informer mon dreamer d'un changement", match_chat_path(chat), class: "card-action-btn card-action-inform" %>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# ===================================================================== %>
  <%# MY MATCHES (projects I applied to)                                    %>
  <%# ===================================================================== %>
  <div class="dashboard-section">
    <div class="dashboard-section-head">
      <h2>Mes matchs</h2>
    </div>

    <% if @maker_projects.empty? %>
      <p class="dashboard-empty">Vous n'avez pas de candidature pour le moment.</p>
    <% else %>
      <% @maker_projects.each do |mp| %>
        <%# The whole row is a link to the related project page %>
        <%= link_to project_path(mp.project, from: "dashboard"), class: "match-row" do %>

          <%# For a maker, the other person is the dreamer who posted the project %>
          <% dreamer = mp.project.dreamer %>

          <%# Dreamer photo + project title and dreamer name (left side) %>
          <div class="match-person">
            <% if dreamer.profile_picture_url.present? %>
              <%= image_tag dreamer.profile_picture_url, class: "match-avatar", alt: dreamer.username %>
            <% else %>
              <%= image_tag "https://kitt.lewagon.com/placeholder/users/ssaunier", class: "match-avatar", alt: dreamer.username %>
            <% end %>
            <span class="match-title"><%= mp.project.title %> — <%= dreamer.username %></span>
          </div>

          <%# Colored badge depending on the status of the application %>
          <% if mp.status == "delivered" %>
            <span class="status-badge status-delivered">Livré</span>
          <% elsif mp.status == "made" %>
            <span class="status-badge status-made">Réalisé</span>
          <% elsif mp.status == "accepted" %>
            <span class="status-badge status-accepted">Match !</span>
          <% elsif mp.status == "rejected" %>
            <span class="status-badge status-rejected">Refusé</span>
          <% else %>
            <span class="status-badge status-pending">En attente</span>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  </div>

  <%# ===================================================================== %>
  <%# MY DISCUSSIONS                                                        %>
  <%# ===================================================================== %>
  <%# -----PROJETS DISPONIBLES (postés par les dreamers, pas encore acceptés)------ %>
  <div>
    <h2>Projets disponibles</h2>

      <%= form_with url: dashboard_path, method: :get, data: { turbo_stream: true } do %>
        <div class="mb-4 d-flex align-items-center gap-2">

      <%= select_tag :category,
        options_for_select(
          [["Toutes les catégories", ""]] + User::SKILLS,
          params[:category]
        ),
        class: "form-select",
        onchange: "this.form.requestSubmit();"
      %>

        </div>
      <% end %>

    <div class="row" id="unmatched-projects">
      <%# Loop over every open project not yet accepted by a maker %>
      <% @open_projects.each do |project| %>
        <div class="col-md-3 mb-4">
          <%# Wrapper kept relative so the action buttons can sit over the card %>
          <div class="project-card-wrapper">
            <%# Link to the project details page %>
            <%= link_to project_path(project, from: "dashboard"), class: "home-project-link" do %>
              <div class="card-trip">
                <%# Status badge shown over the image %>
                <span class="card-status status-badge <%= project.matched? ? 'status-accepted' : 'status-pending' %>"><%= project.status_label %></span>
                <%# Project image, or a placeholder if there is none %>
                <% if project.image.attached? %>
                  <%= image_tag project.image %>
                <% else %>
                  <img src="https://raw.githubusercontent.com/lewagon/fullstack-images/master/uikit/greece.jpg" />
                <% end %>
                <div class="card-trip-infos">
                  <div>
                    <%# Project title %>
                    <h2><%= project.title %></h2>
                  </div>
                </div>
              </div>
            <% end %>
            <%# Action buttons placed over the card, outside the link to avoid nested links %>
            <div class="project-card-actions">
              <%# Match this project: creates the match and opens the discussion %>
              <%= link_to "🤝 Matcher", match_project_path(project), data: { turbo_method: :post }, class: "card-action-btn card-action-match" %>
              <%# Dismiss this project: it will no longer appear in my available projects %>
              <%= link_to "✕ Pas pour moi", dismiss_project_path(project), data: { turbo_method: :post }, class: "card-action-btn card-action-dismiss" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# -----Mes DISCUSSIONS------ %>
  <div>
    <h2>Mes Discussions</h2>

    <% if @match_chats.empty? %>
      <p class="dashboard-empty">Vous n'avez pas de discussion pour le moment.</p>
    <% else %>
      <%# Two columns: the list of discussions on the left, the open one on the right %>
      <div class="discussions-layout">

        <%# Left column: one clickable line per discussion %>
        <div class="discussions-list">
          <% @match_chats.each do |chat| %>
            <%# For a maker, the other person is the dreamer %>
            <% other = chat.maker_project.project.dreamer %>
            <%# Clicking a line loads its conversation in the right frame (no reload) %>
            <%= link_to match_chat_path(chat), class: "discussion-row",
                        data: { turbo_frame: "conversation" } do %>
              <%# Profile picture of the other person (or a placeholder) %>
              <% if other.profile_picture_url.present? %>
                <%= image_tag other.profile_picture_url, class: "discussion-avatar", alt: other.username %>
              <% else %>
                <%= image_tag "https://kitt.lewagon.com/placeholder/users/ssaunier", class: "discussion-avatar", alt: other.username %>
              <% end %>
              <div class="discussion-info">
                <div class="discussion-name"><%= other.username %></div>
                <div class="discussion-project"><%= chat.maker_project.project.title %></div>
              </div>

              <%# Red badge with the number of unread messages in this discussion %>
              <% unread = chat.unread_count_for(current_user) %>
              <% if unread.positive? %>
                <span class="discussion-unread"><%= unread %></span>
              <% end %>
            <% end %>
          <% end %>
        </div>

        <%# Right column: the selected conversation loads inside this frame %>
        <%= turbo_frame_tag "conversation", class: "discussions-conversation" do %>
          <p class="discussions-empty text-muted">Sélectionnez une discussion pour l'afficher.</p>
        <% end %>

      </div>
    <% end %>
  </div>

</div>
