<div class="container" id="dreamer-dashboard">

  <h1>Mon Tableau de Bord Maker</h1>

  <%# -----Mes PROJETS------ %>
  <div>
  <h2>Mes Projets</h2>

  <div class="row">
    <% @maker_projects.each do |maker_project| %>
      <% project = maker_project.project %>
      <%= link_to project_path(project) do %>
        <div class="card-trip">
          <% if project.image.attached? %>
            <%= image_tag project.image %>
          <% else %>
            <img src="https://raw.githubusercontent.com/lewagon/fullstack-images/master/uikit/greece.jpg" />
          <% end %>

          <div class="card-trip-infos">
            <div>
              <h2><%= project.title %></h2>
              <p><%= project.description %></p>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
# IMPORTANT !!!!!!!!!!
  <%= link_to "Voir plus ...", projects_path %>
</div>

  <%# -----Mes DISCUSSIONS------ %>
  <div>
    <h2>Mes Discussions</h2>

    <% @match_chats.each do |chat| %>
      <%= link_to match_chat_path(chat) do %>
        <div>
          <span>Chat avec <%= chat.maker_project.project.dreamer.username %></span>
        </div>
      <% end %>
    <% end %>
  </div>

</div>
